{
  "name": "Windows Copilot API",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "postCreateCommand": "pip install -r requirements.txt && playwright install chromium",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Copilot API",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
